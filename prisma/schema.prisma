// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  name      String
  age       Int
  collegeId String   @unique
  email     String   @unique
  password  String
  contactNo String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  passes    Pass[]
  rides     Ride[]
}

model Station {
  id        String   @id @default(cuid())
  name      String   @unique
  latitude  Float?
  longitude Float?
  bikes     Bike[]
  ridesFrom Ride[]   @relation("StartStation")
  ridesTo   Ride[]   @relation("EndStation")
}

model Bike {
  id        String   @id @default(cuid())
  stationId String
  station   Station  @relation(fields: [stationId], references: [id])
  status    String   @default("AVAILABLE") // AVAILABLE, IN_USE, MAINTENANCE
  battery   Int      @default(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rides     Ride[]
}

model Ride {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  bikeId         String
  bike           Bike      @relation(fields: [bikeId], references: [id])
  startStationId String
  startStation   Station   @relation("StartStation", fields: [startStationId], references: [id])
  endStationId   String?
  endStation     Station?  @relation("EndStation", fields: [endStationId], references: [id])
  planDuration   Int       @default(5) // Default to 5 mins
  startTime      DateTime?
  endTime        DateTime?
  otpCode        String?
  status         String    @default("PENDING") // PENDING, ACTIVE, COMPLETED, PAID
  cost           Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Pass {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // DAILY, WEEKLY, MONTHLY
  expiresAt DateTime
  createdAt DateTime @default(now())
}
